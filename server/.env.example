# Node backend environment variables
# Copy this file to server/.env and fill in values

# Port for the Node.js backend (default: 3001)
PORT=3001

# URL of the Python ML microservice (default: http://localhost:8000)
PYTHON_ML_URL=http://localhost:8000

# When true (default), return demo placeholder predictions if the Python
# ML service is unreachable instead of returning a hard 502 error.
# Set to false in production when the Python service is always expected to run.
ENABLE_DEMO_FALLBACK=true
