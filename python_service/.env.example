# Python ML service environment variables
# Copy this file to python_service/.env and fill in paths

# Absolute path to the saved retinal validator model (.pt / .pth)
# If not set, a heuristic fallback is used.
MODEL_PATH_VALIDATOR=

# Absolute path to the saved ODIR multi-label prediction model (.pt / .pth)
# If not set, placeholder predictions are returned.
MODEL_PATH_ODIR=

# (Optional) Absolute path to the saved APTOS DR grading model (.pt / .pth)
MODEL_PATH_APTOS=

# Decision threshold for the retinal validator MODEL (0–1, default 0.5)
# Only used when MODEL_PATH_VALIDATOR is set.
THRESHOLD_RETINAL=0.5

# Brightness-ratio threshold used by the HEURISTIC validator (no model).
# Inside-circle mean / outside-circle mean must exceed this to pass.
# Default 1.5.  Lower values = more permissive (accepts more images).
THRESHOLD_HEURISTIC_RETINAL=1.5

# Threshold applied per ODIR label (0–1, default 0.4)
THRESHOLD_ODIR=0.4

# Model version string included in prediction responses
MODEL_VERSION=dev
